# ── Template d'environnement — WeBuild (cf. docs/draft-infra-poc.md) ───────
# Variables LUES CÔTÉ SERVEUR UNIQUEMENT (server actions / API) : pas de
# préfixe NEXT_PUBLIC_, donc jamais exposées au navigateur.
#
# DEUX fichiers réels (tous deux gitignorés via `.env*.local`) :
#   • .env.local             → DEV LOCAL   (chargé par `next dev`)
#   • .env.production.local  → PROD COOLIFY (chargé quand NODE_ENV=production ;
#                               ou colle ces valeurs dans l'UI Coolify > Env)
#
# La SEULE différence entre les deux = FIRECRAWL_API_URL (voir ci-dessous).
# Récupérer la clé LiteLLM : `ssh coolify "docker exec litellm-<id> printenv LITELLM_MASTER_KEY"`.

# ── Crawl : Firecrawl self-hosted, moteur UNIQUE (rendu JS, aucune clé) ────
#   PROD  : http://10.10.0.1:3002   (WireGuard — joignable depuis les conteneurs Coolify)
#   LOCAL : http://localhost:3002   via un tunnel SSH à laisser tourner :
#             ssh -N -L 3002:10.10.0.1:3002 coolify
#   ⚠️ Pas de fallback : sans Firecrawl joignable, la capture échoue.
FIRECRAWL_API_URL=
FIRECRAWL_API_KEY=

# ── Passerelle LLM : LiteLLM (domaine public, identique prod & local) ──────
# /health = 401 sans clé. Sans LITELLM_API_KEY, l'extraction éditoriale bascule
# sur un fallback déterministe (la boucle capture→carte tourne quand même).
# TODO infra §7 : virtual key dédiée `sk-webuild` au lieu de la master key.
LITELLM_BASE_URL=https://litellm.augmenter.pro
LITELLM_API_KEY=

# Admin produit (bypass quota rescan + acces fiches carte) — e-mails separes par des virgules
WEBUILD_ADMIN_EMAILS=
