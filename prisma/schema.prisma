// Schéma Prisma — socle de persistance P1 (WeBuild — Trading Authority Game).
//
// Périmètre P1 STRICT : modèles Better Auth (User/Session/Account/Verification)
// + domaine produit (Site / Card / AuthoritySnapshot). Les modèles de la boucle
// de jeu P3 (EditorialLink, CreditLedgerEntry, Promotion…) viendront en P3 et
// seront 100 % additifs grâce aux amendements rétro-imposés intégrés ici
// (cf. docs/plans/p3-game-loop-data-model.md §7 → P1-C1..C4, P1-I2, P1-I3).
//
// ⚠ Prisma 7 : provider `prisma-client` (Rust-free, requiert un driver adapter
// au runtime, cf. lib/db.ts). pgvector préexiste dans webuild_db et le rôle
// applicatif n'est PAS superuser → l'extension `vector` est seulement DÉCLARÉE
// ici (postgresqlExtensions) mais le CREATE EXTENSION est retiré de la migration
// (cf. note dans la migration init-p1).

generator client {
  provider        = "prisma-client"
  output          = "../lib/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  // ⚠ Prisma 7 : `url` n'est plus accepté dans le datasource → la connexion
  // vit dans prisma.config.ts (Migrate) et dans l'adapter (runtime, lib/db.ts).
  // `vector` (pgvector 0.8.2) et `uuid-ossp` préexistent dans webuild_db.
  // Déclarés pour que Prisma connaisse les types ; le CREATE EXTENSION est
  // retiré de la migration car le rôle `webuild` n'est pas superuser.
  extensions = [vector, uuidOssp(map: "uuid-ossp")]
}

// ────────────────────────────────────────────────────────────────────────────
// Modèles Better Auth (schéma standard ; l'auth elle-même est configurée en 4a)
// ────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions Session[]
  accounts Account[]
  sites    Site[]
  cards    Card[]

  // ── Boucle de jeu P3 (relations inverses ; additif, n'altère pas le SQL `user`) ──
  creditLedgerEntries CreditLedgerEntry[]
  donatedLinks        EditorialLink[]    @relation("LinkDonor")
  receivedLinks       EditorialLink[]    @relation("LinkBeneficiary")
  promotions          Promotion[]
  matchingSessions    MatchingSession[]
  gscImportBatches    GscImportBatch[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  // Scopes OAuth concédés (dont `webmasters.readonly` GSC, demandé dès P1).
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ────────────────────────────────────────────────────────────────────────────
// Domaine produit
// ────────────────────────────────────────────────────────────────────────────

/// Cycle de vie d'un site capturé. PENDING avant la 1re capture réussie.
enum SiteStatus {
  PENDING
  CAPTURING
  READY
  FAILED
}

/// Un site déclaré par un membre. Matière première de la carte + du score.
/// `markdown` est stocké (@db.Text) pour recalculer le score en P2 sans re-crawl.
model Site {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  url         String
  domain      String
  status      SiteStatus @default(PENDING)

  // Contenu capturé (Firecrawl) — source du score d'autorité.
  title         String?
  description   String?
  markdown      String? @db.Text
  internalLinks Int?
  externalLinks Int?
  imageCount    Int?
  https         Boolean?

  // Clés de classification (P1-C1/C2) — alimentées par extractEditorial.
  // `element`    : tech | finance | media | sante | cuisine | encyclopedie
  // `thematique` : TECH | FINANCE | PRESSE | CUISINE | ENCYCLOPEDIE …
  // Indexées : clés du matching P3 + clusterKey d'amortissement.
  element    String?
  thematique String?

  // Embedding topical (P1-C3) — NULL en P1, alimenté en P3 (matching pgvector).
  // 1536d (modèle gte-qwen2-local). Type non géré nativement → Unsupported.
  embedding Unsupported("vector(1536)")?

  /// Dernier rescan Firecrawl demandé par le membre (quota 1/semaine ; admin illimité).
  lastRescanAt DateTime?

  // ── P4 : assets visuels Tier 1 (logo / hero / screenshot homepage) ──
  logoUrl               String?
  heroImageUrl          String?
  homepageScreenshotUrl String?
  /// Provenance des assets (`SiteVisualAssets.provenance`) pour debug / re-score.
  visualProvenanceJson  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  card      Card?
  snapshots AuthoritySnapshot[]

  // ── P2 : historique GSC first-party (insert-only) ──
  gscSnapshots GscSnapshot[]

  // ── P3 : liens éditoriaux où ce site est donneur / bénéficiaire ──
  linksDonated  EditorialLink[]      @relation("DonorSite")
  linksReceived EditorialLink[]      @relation("BeneficiarySite")
  suggestionsFrom EditorialSuggestion[] @relation("SuggestionSource")
  suggestionsTo   EditorialSuggestion[] @relation("SuggestionTarget")
  clusterAmortizations DonorClusterAmortization[]

  @@unique([userId, domain])
  @@index([userId])
  @@index([element])
  @@index([thematique])
  @@index([status])
  @@map("site")
}

/// La carte TCG dérivée d'un site (1-1). Stocke TOUS les champs TCG (même en
/// placeholder) → on ne carve pas Card/CardView prématurément (cf. blueprint P1
/// et lib/domain/card.ts). `userId` dénormalisé (P1-I2) pour éviter un N+1 sur
/// le deck (findMany where userId sans jointure obligatoire).
model Card {
  id     String @id @default(uuid())
  siteId String @unique
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Dérivés du score (snapshot courant aplati pour lecture rapide).
  level Int // 1..4 (Level)
  hp    Int
  atk   Int
  tf    Int
  cf    Int
  dr    Int

  // Champs éditoriaux / présentation.
  anchor     String  @default("")
  element    String // tech | finance | media | sante | cuisine | encyclopedie
  thematique String
  summary    String  @db.Text

  // Couche TCG (placeholders "—"/0 acceptés en P1).
  linkType     String @default("dofollow") // dofollow | nofollow | sponsored
  status       String @default("dispo") // CardState : dispo | en-echange | acquise | verrouillee
  price        Int    @default(0)
  edition      String @default("—")
  editionTotal String @default("—")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([level])
  @@map("card")
}

/// Historique insert-only du score d'autorité (jamais d'UPDATE/DELETE).
/// `metricVersion` ("v1-onpage" → "v2-gsc") trace la recalibration P2.
/// `signalsJson` stocke le détail des signaux + element/thematique (P1-I3)
/// pour éviter de reparser le markdown en P3.
model AuthoritySnapshot {
  id     String @id @default(uuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  score Int
  level Int
  hp    Int
  atk   Int
  tf    Int
  cf    Int
  dr    Int

  // Détail brut des AuthoritySignal[] + element/thematique extraits (P1-I3).
  signalsJson   Json
  metricVersion String @default("v1-onpage")

  createdAt DateTime @default(now())

  @@index([siteId, createdAt(sort: Desc)])
  @@map("authority_snapshot")
}

// ────────────────────────────────────────────────────────────────────────────
// P2 — Google Search Console first-party (SEO Tier 2)
// ────────────────────────────────────────────────────────────────────────────

/// Source d'un snapshot GSC : `OAUTH` (API webmasters.readonly, infalsifiable,
/// preuve de propriété) vs `SCREENSHOT` (fallback gemma4-vision, forgeable →
/// poids plafonné / anti-fraude). cf. docs/draft-metrique-autorite.md §2.
enum GscSource {
  OAUTH
  SCREENSHOT
}

/// Historique insert-only des données Search Console d'un site (jamais
/// d'UPDATE/DELETE), miroir d'AuthoritySnapshot. Alimente le sous-score S_seo
/// Tier 2 (impressions/position réelles, fort poids si OAUTH). La période GSC
/// est fenêtrée (startDate→endDate) ; les agrégats sont des moyennes/sommes sur
/// la fenêtre ; `rawJson` conserve le payload brut (rows GSC / lecture vision)
/// pour recalcul sans re-fetch. cf. docs/draft-metrique-autorite.md §2 (Tier 2).
model GscSnapshot {
  id     String @id @default(uuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  source GscSource @default(OAUTH)

  // Fenêtre temporelle couverte par les données GSC (date-only côté GSC).
  startDate DateTime
  endDate   DateTime

  // Agrégats sur la fenêtre (clics/impressions = sommes ; ctr/position =
  // moyennes pondérées). `indexedPages` = nb de pages indexées (Coverage),
  // nullable car non fourni par l'API Search Analytics seule.
  clicks       Int
  impressions  Int
  ctr          Float
  position     Float
  queryCount   Int?
  /** URLs distinctes avec impressions (Search Analytics, dimension `page`, fenêtre). */
  pageCount    Int?
  /** Pages indexées (API Sitemaps `contents[].indexed`, type web). */
  indexedPages Int?
  /** Pages soumises via sitemap (API Sitemaps `contents[].submitted`). */
  sitemapSubmittedPages Int?

  // Payload brut (rows Search Analytics API ou extraction vision du screenshot)
  // → recalcul du score sans re-fetch, et audit anti-fraude du fallback.
  rawJson Json

  fetchedAt DateTime @default(now())

  @@index([siteId, fetchedAt(sort: Desc)])
  @@map("gsc_snapshot")
}

/// Cycle de vie d'un lot d'import GSC (déclaration multi-sites).
enum GscImportBatchStatus {
  PENDING
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
  CANCELLED
}

/// Cycle de vie d'une propriété GSC dans un lot.
enum GscImportItemStatus {
  PENDING
  RUNNING
  COMPLETED
  SKIPPED
  FAILED
}

/// Lot d'import Search Console lancé par un membre (traité par worker/cron).
/// Chaque item = 1 propriété GSC → Firecrawl + carte + snapshot GSC (score v2).
model GscImportBatch {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status GscImportBatchStatus @default(PENDING)

  /// Politique au moment du lancement (ex. délégués autorisés via flag produit).
  allowDelegated Boolean @default(false)

  totalItems     Int @default(0)
  completedItems Int @default(0)
  failedItems    Int @default(0)
  skippedItems   Int @default(0)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  startedAt  DateTime?
  finishedAt DateTime?

  items GscImportBatchItem[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("gsc_import_batch")
}

/// Une propriété GSC à importer dans un lot (1 domaine logique par item).
model GscImportBatchItem {
  id      String @id @default(uuid())
  batchId String
  batch   GscImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  /// Forme exacte GSC (`sc-domain:` ou préfixe URL).
  gscProperty     String
  permissionLevel String
  domain          String
  captureUrl      String

  status GscImportItemStatus @default(PENDING)

  siteId String?
  cardId String?
  error  String? @db.Text

  attempts   Int @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  startedAt  DateTime?
  finishedAt DateTime?

  @@unique([batchId, gscProperty])
  @@index([batchId, status])
  @@index([status])
  @@map("gsc_import_batch_item")
}

// ════════════════════════════════════════════════════════════════════════════
// P3 — Boucle de jeu (liens éditoriaux, crédits, promotions, matching,
// anti-footprint). 100 % additif : nouvelles tables + FK vers user/site/card.
// Modèles repris de docs/plans/p3-game-loop-data-model.md §2.
// Principe : flux UNIDIRECTIONNEL non-réciproque — aucune FK Promotion→Link,
// aucun couplage donneur↔bénéficiaire (lien = propriété émergente du graphe).
// Solde crédits = SUM(amount) du ledger, jamais dénormalisé.
// ════════════════════════════════════════════════════════════════════════════

/// Nature du lien obtenu. `MENTION` (sans href) est valorisée pour le GEO
/// (citation > link juice). cf. doctrine éditoriale + draft-vision-geo.
enum LinkNature {
  DOFOLLOW
  NOFOLLOW
  SPONSORED
  UGC
  MENTION
}

/// Cycle de vie d'un lien éditorial. Frappe des crédits À LA VÉRIFICATION SEULE
/// (VERIFIED) ; BROKEN/REJECTED déclenchent un clawback (transaction inverse).
enum LinkStatus {
  PROPOSED
  HUMAN_VALIDATED
  PUBLISHED
  PROOF_PENDING
  VERIFIED
  BROKEN
  REJECTED
}

/// Type d'ancre — quota de diversité anti-footprint (pas que de l'exact-match).
enum AnchorType {
  EXACT
  PARTIAL
  BRANDED
  NAKED_URL
  GENERIC
  IMAGE
}

/// Raison d'un mouvement de crédits dans le ledger (registre de mouvements).
enum CreditTxReason {
  LINK_VERIFIED
  LINK_CLAWBACK
  PROMOTION_SPEND
  PROMOTION_REFUND
  BONUS
  ADJUSTMENT
}

/// Cycle de vie d'une promotion (visibilité achetée dans le matching).
enum PromotionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

/// Cycle de vie d'une suggestion IA (édition humaine obligatoire avant lien).
enum SuggestionStatus {
  GENERATED
  HUMAN_EDITED
  ACCEPTED
  REJECTED
  EXPIRED
}

/// État de la preuve de publication d'un lien (capture Firecrawl).
enum ProofStatus {
  PENDING
  CONFIRMED
  NOT_FOUND
  ERROR
}

/// Registre de mouvements de crédits (ledger). SOURCE UNIQUE du solde :
/// `Me.credits = SUM(amount)`. `amount` signé (+ frappe / − dépense ou clawback).
/// FK nullables vers le lien/promotion à l'origine du mouvement (traçabilité).
model CreditLedgerEntry {
  id     String         @id @default(uuid())
  userId String
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount Int
  reason CreditTxReason

  editorialLinkId String?
  editorialLink   EditorialLink? @relation(fields: [editorialLinkId], references: [id])
  promotionId     String?
  promotion       Promotion?     @relation(fields: [promotionId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([editorialLinkId])
  @@index([promotionId])
  @@map("credit_ledger_entry")
}

/// Un lien éditorial donné. DONNEUR (donorSite/donorUser) ≠ BÉNÉFICIAIRE
/// (beneficiarySite/beneficiaryUser) : décorrélation stricte (pas de réciprocité
/// modélisée). Scoring figé au calcul (relevance/quality/amortization →
/// creditsComputed). Cycle de vie horodaté. `suggestionId` nullable (don
/// spontané possible). Index anti-cycle [donorSiteId, beneficiarySiteId].
model EditorialLink {
  id String @id @default(uuid())

  // Donneur (gagne des crédits à la vérification).
  donorSiteId String
  donorSite   Site   @relation("DonorSite", fields: [donorSiteId], references: [id], onDelete: Cascade)
  donorUserId String
  donorUser   User   @relation("LinkDonor", fields: [donorUserId], references: [id], onDelete: Cascade)

  // Bénéficiaire (reçoit le lien). Aucun couplage de transaction avec le donneur.
  beneficiarySiteId String
  beneficiarySite   Site   @relation("BeneficiarySite", fields: [beneficiarySiteId], references: [id], onDelete: Cascade)
  beneficiaryUserId String
  beneficiaryUser   User   @relation("LinkBeneficiary", fields: [beneficiaryUserId], references: [id], onDelete: Cascade)

  // Contenu du lien.
  targetUrl   String
  anchorText  String
  anchorType  AnchorType
  nature      LinkNature @default(DOFOLLOW)
  context     String?    @db.Text
  publishedUrl String?

  // Scoring figé au moment du calcul de crédits.
  relevanceScore    Float?
  qualityScore      Float?
  amortizationFactor Float?
  creditsComputed   Int?

  status LinkStatus @default(PROPOSED)

  // Provenance IA (nullable : don spontané hors suggestion).
  suggestionId String?              @unique
  suggestion   EditorialSuggestion? @relation(fields: [suggestionId], references: [id])

  // Cycle de vie horodaté.
  proposedAt  DateTime  @default(now())
  validatedAt DateTime?
  publishedAt DateTime?
  verifiedAt  DateTime?
  brokenAt    DateTime?

  updatedAt DateTime @updatedAt

  proof         LinkProof?
  ledgerEntries CreditLedgerEntry[]

  @@index([donorSiteId, beneficiarySiteId])
  @@index([donorUserId])
  @@index([beneficiaryUserId])
  @@index([status])
  @@map("editorial_link")
}

/// Preuve de publication d'un lien (1-1). Capture Firecrawl de la page publiée :
/// lien/mention détecté, attribut rel réel, position dans la page ; re-captures
/// (lastCheckedAt/checkCount) pour le job de clawback P4.
model LinkProof {
  id              String        @id @default(uuid())
  editorialLinkId String        @unique
  editorialLink   EditorialLink @relation(fields: [editorialLinkId], references: [id], onDelete: Cascade)

  status          ProofStatus @default(PENDING)
  linkDetected    Boolean     @default(false)
  mentionDetected Boolean     @default(false)
  rel             String?
  positionInPage  Int?

  // Payload brut de la capture (markdown/HTML Firecrawl) pour audit.
  captureJson Json?

  lastCheckedAt DateTime @default(now())
  checkCount    Int      @default(1)
  createdAt     DateTime @default(now())

  @@map("link_proof")
}

/// Dépense de crédits pour de la VISIBILITÉ dans le matching (ciblage par
/// niveau/élément/durée). AUCUNE FK vers un EditorialLink : la promotion achète
/// une visibilité, pas un lien (décorrélation stricte du flux unidirectionnel).
model Promotion {
  id     String          @id @default(uuid())
  userId String
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteId String?
  status PromotionStatus @default(ACTIVE)

  // Ciblage de l'audience promue.
  targetLevel      Int?
  targetElement    String?
  targetThematique String?

  creditsSpent Int

  startsAt  DateTime  @default(now())
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ledgerEntries CreditLedgerEntry[]

  @@index([userId])
  @@index([status, expiresAt])
  @@index([targetElement])
  @@map("promotion")
}

/// Une session de matching IA (trace) : un membre cherche des partenaires.
/// Regroupe les EditorialSuggestion produites (pgvector 3× + rerank + filtres).
model MatchingSession {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Paramètres / trace de la requête (filtres appliqués, modèle, etc.).
  paramsJson Json?

  createdAt DateTime @default(now())

  suggestions EditorialSuggestion[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("matching_session")
}

/// Une suggestion IA (source → cible) : sujet d'article + ancre proposés.
/// `embedding` (vector 1536d) pour la dédup sémantique anti-footprint.
/// `naturalScore` = score de naturalité ; `humanEdited*` = version validée
/// (édition humaine OBLIGATOIRE avant de créer un EditorialLink).
model EditorialSuggestion {
  id                String          @id @default(uuid())
  matchingSessionId String
  matchingSession   MatchingSession @relation(fields: [matchingSessionId], references: [id], onDelete: Cascade)

  sourceSiteId String
  sourceSite   Site   @relation("SuggestionSource", fields: [sourceSiteId], references: [id], onDelete: Cascade)
  targetSiteId String
  targetSite   Site   @relation("SuggestionTarget", fields: [targetSiteId], references: [id], onDelete: Cascade)

  // Contenu généré.
  articleTopic       String  @db.Text
  proposedAnchor     String
  proposedAnchorType AnchorType?
  rationale          String? @db.Text

  // Dédup sémantique anti-footprint (1536d, gte-qwen2-local). Unsupported.
  embedding Unsupported("vector(1536)")?

  // Scores de garde-fous.
  relevanceScore Float?
  naturalScore   Float?

  status SuggestionStatus @default(GENERATED)

  // Version éditée par l'humain (traçabilité IA vs humain).
  humanEditedTopic  String? @db.Text
  humanEditedAnchor String?
  editedAt          DateTime?

  createdAt DateTime @default(now())

  link EditorialLink?

  @@index([matchingSessionId])
  @@index([sourceSiteId])
  @@index([targetSiteId])
  @@index([status])
  @@map("editorial_suggestion")
}

/// Snapshot anti-footprint à l'échelle plateforme (ou cluster) : diversité des
/// ancres/angles, densité du graphe de liens, vélocité de création → score de
/// naturalité agrégé. Insert-only (série temporelle d'observabilité).
model NaturalnessSnapshot {
  id String @id @default(uuid())

  // Portée du snapshot : NULL = plateforme entière, sinon une clé de cluster
  // (élément / thématique). Pas de FK : portée logique, pas une entité.
  scopeKey String?

  anchorDiversity Float?
  angleDiversity  Float?
  graphDensity    Float?
  velocity        Float?
  naturalnessScore Float?

  // Détail des métriques calculées (histogrammes ancres/angles, etc.).
  metricsJson Json?

  createdAt DateTime @default(now())

  @@index([scopeKey, createdAt(sort: Desc)])
  @@map("naturalness_snapshot")
}

/// Amortissement par cluster de donneur en fenêtre glissante : 2ᵉ filet
/// orthogonal à l'anti-cycle (réduit les crédits frappés si un site/cluster
/// donne trop de liens dans une fenêtre → décroissance économique).
/// `clusterKey` = granularité à calibrer (siteId / élément / cluster pgvector,
/// Q-P3-1). Insert-only ; le facteur courant = dernière entrée de la fenêtre.
model DonorClusterAmortization {
  id String @id @default(uuid())

  donorSiteId String
  donorSite   Site   @relation(fields: [donorSiteId], references: [id], onDelete: Cascade)
  clusterKey  String

  windowStart DateTime
  windowEnd   DateTime
  linkCount   Int     @default(0)
  amortizationFactor Float

  createdAt DateTime @default(now())

  @@index([donorSiteId, createdAt(sort: Desc)])
  @@index([clusterKey])
  @@map("donor_cluster_amortization")
}
